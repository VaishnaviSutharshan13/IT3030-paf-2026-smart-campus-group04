{
  "name": "smart-campus-operations-hub",
  "private": true,
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "SPRING_DATASOURCE_USERNAME=${SPRING_DATASOURCE_USERNAME:-smart_user} SPRING_DATASOURCE_PASSWORD=${SPRING_DATASOURCE_PASSWORD:-StrongPass!123} mvn -f backend/pom.xml spring-boot:run",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "mvn -f backend/pom.xml clean package",
    "build:frontend": "npm --prefix frontend run build",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "mvn -f backend/pom.xml test",
    "test:frontend": "npm --prefix frontend run test"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
